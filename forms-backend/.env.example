# Required: Initial admin account (only used on first seed)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-strong-password

# Required: Session encryption secret (generate a random string)
SESSION_SECRET=generate-a-random-string-here-at-least-32-chars

# Required: Your main site URL (no trailing slash)
SITE_URL=https://bitcoin.rocks

# Optional: Database path (Railway will set this to the persistent volume)
# DB_PATH=/data/forms.db

# Optional: Port (Railway sets this automatically)
# PORT=3000

# Set to 'production' on Railway
NODE_ENV=production
