<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= form.name %> — bitcoin.rocks Forms</title>
  <link rel="stylesheet" href="/admin/static/admin.css">
</head>
<body>
  <nav class="navbar">
    <div class="nav-left">
      <span class="nav-logo">₿</span>
      <a href="/admin" class="nav-brand">Forms Admin</a>
    </div>
    <div class="nav-right">
      <span class="nav-user"><%= user.username %><% if (user.is_admin) { %> <span class="badge">admin</span><% } %></span>
      <% if (user.is_admin) { %>
        <a href="/admin/users" class="nav-link">Users</a>
      <% } %>
      <a href="/admin/logout" class="nav-link">Log out</a>
    </div>
  </nav>

  <div class="container">
    <a href="/admin" class="back-link">← Back to Dashboard</a>

    <div class="form-header">
      <div>
        <h2><%= form.name %></h2>
        <p class="subtitle"><%= submissions.length %> submission<%= submissions.length !== 1 ? 's' : '' %></p>
      </div>
      <div class="form-actions">
        <% if (submissions.length > 0) { %>
          <a href="/admin/forms/<%= form.slug %>/csv" class="btn btn-secondary">⬇ Export CSV</a>
        <% } %>
      </div>
    </div>

    <% if (submissions.length > 0) { %>
      <div class="table-wrapper">
        <table>
          <thead>
            <tr>
              <th class="checkbox-col">
                <input type="checkbox" id="select-all" title="Select all">
              </th>
              <% fields.forEach(field => { %>
                <th><%= field %></th>
              <% }) %>
              <th>submitted</th>
            </tr>
          </thead>
          <tbody>
            <% submissions.forEach(sub => { %>
              <tr>
                <td class="checkbox-col">
                  <input type="checkbox" name="ids" value="<%= sub.id %>" class="row-checkbox"
                    <% if (sub.data.address1) { %>data-address="<%= sub.data.address1 %>"<% } %>>
                </td>
                <% fields.forEach(field => { %>
                  <td><%= sub.data[field] || '' %></td>
                <% }) %>
                <td class="date-col">
                  <%= new Date(sub.submitted_at + 'Z').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                  <span class="time"><%= new Date(sub.submitted_at + 'Z').toLocaleTimeString('en-US', { hour: '2-digit', minute: '2-digit' }) %></span>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <div class="bulk-actions">
        <form method="POST" action="/admin/forms/<%= form.slug %>/delete" id="delete-form" class="inline-action">
          <div id="hidden-ids-delete"></div>
          <button type="submit" class="btn btn-danger" id="delete-selected" disabled>Delete Selected</button>
        </form>
        <% if (region && canBlacklist) { %>
          <form method="POST" action="/admin/forms/<%= form.slug %>/blacklist" id="blacklist-form" class="inline-action">
            <div id="hidden-ids-blacklist"></div>
            <button type="submit" class="btn btn-blacklist" id="blacklist-selected" disabled>Blacklist Address</button>
          </form>
        <% } %>
      </div>

      <div class="danger-zone">
        <h4>Danger Zone</h4>
        <p>Permanently delete all <%= submissions.length %> submission<%= submissions.length !== 1 ? 's' : '' %> for this form. This cannot be undone.</p>
        <form method="POST" action="/admin/forms/<%= form.slug %>/delete-all" onsubmit="return confirm('Are you sure you want to permanently delete ALL <%= submissions.length %> submissions? This cannot be undone.')">
          <button type="submit" class="btn btn-danger">Delete All Submissions</button>
        </form>
      </div>
    <% } else { %>
      <div class="empty-state">
        <p>No submissions yet for this form.</p>
        <p>Submissions will appear here when users fill out the form on your website.</p>
      </div>
    <% } %>

    <% if (region && canBlacklist) { %>
      <div class="blacklist-section">
        <h3>Blacklisted Addresses — <%= region.toUpperCase() %></h3>
        <p class="blacklist-note">This blacklist is shared across all <strong><%= region.toUpperCase() %></strong> forms. Blacklisted addresses are silently rejected — the submitter sees the success page but the submission is never saved.</p>

        <% if (blacklistedAddresses.length > 0) { %>
          <div class="table-wrapper">
            <table>
              <thead>
                <tr>
                  <th>Address</th>
                  <th>Blocked</th>
                  <th>Added By</th>
                  <th>Date Added</th>
                  <th></th>
                </tr>
              </thead>
              <tbody>
                <% blacklistedAddresses.forEach(entry => { %>
                  <tr>
                    <td><%= entry.address_original %></td>
                    <td class="blocked-count">
                      <span class="blocked-badge"><%= entry.blocked_count %></span>
                    </td>
                    <td><%= entry.created_by_username || 'Unknown' %></td>
                    <td class="date-col">
                      <%= new Date(entry.created_at + 'Z').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %>
                    </td>
                    <td>
                      <form method="POST" action="/admin/forms/<%= form.slug %>/blacklist/<%= entry.id %>/remove" class="inline-action" onsubmit="return confirm('Remove this address from the blacklist?')">
                        <button type="submit" class="btn btn-danger btn-small">Remove</button>
                      </form>
                    </td>
                  </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        <% } else { %>
          <p class="blacklist-empty">No addresses are currently blacklisted for <%= region.toUpperCase() %> forms.</p>
        <% } %>

      </div>
    <% } %>
  </div>

  <script>
    // Select all checkbox
    document.getElementById('select-all')?.addEventListener('change', function() {
      const checkboxes = document.querySelectorAll('.row-checkbox');
      checkboxes.forEach(cb => cb.checked = this.checked);
      updateButtons();
    });

    // Enable/disable buttons based on selection
    document.querySelectorAll('.row-checkbox').forEach(cb => {
      cb.addEventListener('change', updateButtons);
    });

    function updateButtons() {
      const checked = document.querySelectorAll('.row-checkbox:checked');
      const deleteBtn = document.getElementById('delete-selected');
      const blacklistBtn = document.getElementById('blacklist-selected');

      if (deleteBtn) {
        deleteBtn.disabled = checked.length === 0;
        deleteBtn.textContent = checked.length > 0
          ? `Delete Selected (${checked.length})`
          : 'Delete Selected';
      }

      if (blacklistBtn) {
        // Count how many selected have an address1
        let addressCount = 0;
        checked.forEach(cb => {
          if (cb.dataset.address && cb.dataset.address.trim() !== '') addressCount++;
        });
        blacklistBtn.disabled = addressCount === 0;
        blacklistBtn.textContent = addressCount > 0
          ? `Blacklist Address (${addressCount})`
          : 'Blacklist Address';
      }
    }

    // Sync checked IDs into hidden inputs before form submit
    function syncHiddenIds(formEl, containerId) {
      const container = document.getElementById(containerId);
      container.innerHTML = '';
      const checked = document.querySelectorAll('.row-checkbox:checked');
      checked.forEach(cb => {
        const input = document.createElement('input');
        input.type = 'hidden';
        input.name = 'ids';
        input.value = cb.value;
        container.appendChild(input);
      });
    }

    // Confirm before deleting selected
    document.getElementById('delete-form')?.addEventListener('submit', function(e) {
      const count = document.querySelectorAll('.row-checkbox:checked').length;
      if (count === 0) {
        e.preventDefault();
        return;
      }
      if (!confirm(`Permanently delete ${count} submission${count !== 1 ? 's' : ''}? This cannot be undone.`)) {
        e.preventDefault();
        return;
      }
      syncHiddenIds(this, 'hidden-ids-delete');
    });

    // Confirm before blacklisting
    document.getElementById('blacklist-form')?.addEventListener('submit', function(e) {
      const checked = document.querySelectorAll('.row-checkbox:checked');
      let addressCount = 0;
      checked.forEach(cb => {
        if (cb.dataset.address && cb.dataset.address.trim() !== '') addressCount++;
      });
      if (addressCount === 0) {
        e.preventDefault();
        return;
      }
      if (!confirm('Blacklist ' + addressCount + ' address' + (addressCount !== 1 ? 'es' : '') + '? This will block future submissions from ' + (addressCount === 1 ? 'this address' : 'these addresses') + ' across all <%= region ? region.toUpperCase() : "" %> forms.')) {
        e.preventDefault();
        return;
      }
      syncHiddenIds(this, 'hidden-ids-blacklist');
    });
  </script>
</body>
</html>
